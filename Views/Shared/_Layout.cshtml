<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Lost_Found</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Lost_Found.styles.css" asp-append-version="true" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
</head>
<body class="home-page">
    <!-- ========== NAVBAR ========== -->
    <nav class="hp-navbar">
        <div class="hp-container hp-navbar-inner">
            <a href="/User/Index" class="hp-logo">
                <svg class="hp-logo-icon" width="26" height="26" viewBox="0 0 24 24" fill="#1a7a4c">
                    <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
                </svg>
                <span>Lost & Found</span>
            </a>
            <ul class="hp-nav-links">
                @{
                    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
                    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
                }
                <li><a href="/User/Index" class="@(currentController == "User" && currentAction == "Index" ? "active" : "")">Home</a></li>
                <li><a asp-controller="Items" asp-action="Index" class="@(currentController == "Items" && currentAction == "Index" ? "active" : "")">Browse Items</a></li>
                <li><a asp-controller="Items" asp-action="ReportItem" class="@(currentController == "Items" && currentAction == "ReportItem" ? "active" : "")">Report Item</a></li>
                <li><a asp-controller="Items" asp-action="MyClaims" class="@(currentController == "Items" && currentAction == "MyClaims" ? "active" : "")">My Claims</a></li>
            </ul>
            <div class="hp-nav-auth">
                @if (Context.Session.GetInt32("UserId") != null)
                {
                    <a href="@Url.Action("Index", "Notifications")" class="hp-nav-notification" title="Notifications">
                        <i class="fas fa-bell"></i>
                        <span class="hp-notification-badge"></span>
                    </a>
                    <a href="/User/Profile" class="hp-nav-profile">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
                            <circle cx="12" cy="7" r="4"/>
                        </svg>
                        <span>@Context.Session.GetString("UserName")</span>
                    </a>
                    <a href="/User/Logout" class="hp-nav-logout">Logout</a>
                }
                else
                {
                    <a href="/User/Login" class="hp-nav-login">Login</a>
                    <a href="/User/Register" class="hp-nav-register">Register</a>
                }
            </div>
        </div>
    </nav>
    @RenderBody()

    <!-- ========== FOOTER ========== -->
    <footer class="hp-footer">
        <div class="hp-container">
            <div class="hp-footer-grid">
                <div class="hp-footer-col">
                    <div class="hp-footer-logo">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="#1a7a4c"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/></svg>
                        <span>Lost & Found</span>
                    </div>
                    <p>A dedicated platform for university students to report and retrieve lost or found items on campus efficiently and securely through our trusted community network.</p>
                </div>
                <div class="hp-footer-col">
                    <h4>RESOURCES</h4>
                    <ul>
                        <li><a href="/User/Index">Home</a></li>
                        <li><a asp-controller="Items" asp-action="Index">Browse Items</a></li>
                        <li><a href="/User/Profile">My Account</a></li>
                    </ul>
                </div>
                <div class="hp-footer-col">
                    <h4>LEGAL</h4>
                    <ul>
                        <li><a href="#">Privacy Policy</a></li>
                        <li><a href="#">Terms of Service</a></li>
                    </ul>
                </div>
                <div class="hp-footer-col">
                    <h4>STAY UPDATED</h4>
                    <p>Subscribe to campus alerts to get lost item notifications.</p>
                    <div class="hp-subscribe">
                        <input type="email" placeholder="Your email address" />
                        <button>
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M22 2L11 13"/><path d="M22 2L15 22l-4-9-9-4 20-7z"/></svg>
                        </button>
                    </div>
                </div>
            </div>
            <div class="hp-footer-bottom">
                <p>&copy; 2024 Lost & Found. Built for students.</p>
            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        $(document).ready(function() {
            function updateBadge() {
                $.get('/Notifications/GetUnreadCount', function(count) {
                    const badge = $('.hp-notification-badge');
                    if (count > 0) {
                        badge.text(count > 9 ? '9+' : count).css('display', 'flex');
                    } else {
                        badge.hide();
                    }
                });
            }
            if ($('.hp-nav-notification').length > 0) {
                updateBadge();
                setInterval(updateBadge, 30000); 
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
