<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Admin Portal</title>
    <link rel="stylesheet" href="~/css/admin.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
</head>
<body>
    <!-- Premium Sidebar -->
    <div class="sidebar">
        <div class="logo">
            <i class="fas fa-shield-halved" style="color: #10b981; margin-right: 10px;"></i>
            <span>Lost & Found</span>
        </div>
        <ul class="sidebar-menu">
            <li>
                <a href="@Url.Action("Dashboard", "Admin")" class="@(ViewBag.ActivePage == "Dashboard" ? "active" : "")">
                    <i class="fas fa-chart-pie"></i> Dashboard
                </a>
            </li>
            <li>
                <a href="@Url.Action("LostItems", "Admin")" class="@(ViewBag.ActivePage == "LostItems" ? "active" : "")">
                    <i class="fas fa-search"></i> Lost Items
                </a>
            </li>
            <li>
                <a href="@Url.Action("FoundItems", "Admin")" class="@(ViewBag.ActivePage == "FoundItems" ? "active" : "")">
                    <i class="fas fa-box"></i> Found Items
                </a>
            </li>
            <li>
                <a href="@Url.Action("ManageClaims", "Admin")" class="@(ViewBag.ActivePage == "ManageClaims" ? "active" : "")">
                    <i class="fas fa-hand-holding-heart"></i> Manage Claims
                </a>
            </li>
            <li>
                <a href="@Url.Action("ManageUsers", "Admin")" class="@(ViewBag.ActivePage == "ManageUsers" ? "active" : "")">
                    <i class="fas fa-users-gear"></i> Manage Users
                </a>
            </li>
            <li style="margin-top: auto; border-top: 1px solid rgba(255,255,255,0.05); padding-top: 20px;">
                <a href="@Url.Action("AdminProfile", "Admin")" class="@(ViewBag.ActivePage == "Profile" ? "active" : "")">
                    <i class="fas fa-user-circle"></i> Profile
                </a>
            </li>
            <li>
                <a href="@Url.Action("Logout", "Admin")" style="color: #ef4444;">
                    <i class="fas fa-sign-out-alt"></i> Logout
                </a>
            </li>
        </ul>
    </div>

    <!-- Main Content Area -->
    <div class="main-content">
        <!-- New Admin Topbar -->
        <header class="admin-header">
            <div class="header-breadcrumbs">
                <span style="color: #64748b; font-size: 14px; font-weight: 500;">
                    <i class="fas fa-home" style="margin-right: 4px;"></i> Admin / 
                    <span style="color: #0f172a; font-weight: 600;">@ViewData["Title"]</span>
                </span>
            </div>
            
            <div class="header-actions">
                <a href="@Url.Action("Admin", "Notifications")" class="notification-bell" title="Alerts" style="text-decoration: none;">
                    <i class="fas fa-bell"></i>
                    <span class="admin-badge"></span>
                </a>
                
                <div class="admin-user-info">
                    <div class="admin-avatar">
                        @{
                            var name = Context.Session.GetString("UserName") ?? "Admin";
                            char initial = !string.IsNullOrEmpty(name) ? name[0] : 'A';
                        }
                        @initial
                    </div>
                    <div style="display: flex; flex-direction: column;">
                        <span style="font-size: 14px; font-weight: 600; color: #0f172a;">@name</span>
                        <span style="font-size: 11px; color: #10b981; font-weight: 600; text-transform: uppercase;">Super Admin</span>
                    </div>
                </div>
            </div>
        </header>

        @RenderBody()
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function() {
            function updateAdminBadge() {
                $.get('/Notifications/GetUnreadCount', function(count) {
                    const badge = $('.admin-badge');
                    if (count > 0) {
                        badge.text(count > 9 ? '9+' : count).css('display', 'flex');
                    } else {
                        badge.hide();
                    }
                });
            }
            if ($('.notification-bell').length > 0) {
                updateAdminBadge();
                setInterval(updateAdminBadge, 30000);
            }
        });
    </script>
    @RenderSection("Scripts", required: false)
</body>
</html>