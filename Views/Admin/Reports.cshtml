@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Institutional Analytics";
}

<div class="page-header" style="margin-bottom: 32px;">
    <div class="page-title">
        <h2>Institutional Analytics</h2>
        <p>Analyze campus security data and item recovery trends.</p>
    </div>
</div>

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-info">
            <h3>Registered Users</h3>
            <p>@ViewBag.TotalUsers</p>
        </div>
        <div class="stat-icon users"><i class="fas fa-users"></i></div>
    </div>
    <div class="stat-card">
        <div class="stat-info">
            <h3>Administrative Staff</h3>
            <p>@ViewBag.TotalAdmins</p>
        </div>
        <div class="stat-icon users" style="background: #f0f9ff; color: #0ea5e9;"><i class="fas fa-user-shield"></i></div>
    </div>
    <div class="stat-card">
        <div class="stat-info">
            <h3>Total Inventory</h3>
            <p>@ViewBag.TotalItems</p>
        </div>
        <div class="stat-icon items"><i class="fas fa-box"></i></div>
    </div>
    <div class="stat-card">
        <div class="stat-info">
            <h3>Resolved Claims</h3>
            <p>@ViewBag.ApprovedClaims</p>
        </div>
        <div class="stat-icon claims" style="background: #dcfce7; color: #10b981;"><i class="fas fa-check-double"></i></div>
    </div>
</div>

<div style="background: white; border-radius: 16px; padding: 32px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); margin-bottom: 32px;">
    <h3 style="margin-top: 0; font-size: 18px; font-weight: 700; color: #0f172a; margin-bottom: 24px;">Claim Resolution Efficiency (Mocked Trend)</h3>
    <div style="height: 300px; position: relative;">
        <canvas id="analyticsChart"></canvas>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const ctx = document.getElementById('analyticsChart').getContext('2d');
        new Chart(ctx, {
            type: 'line',
            data: {
                labels: ['Week 1', 'Week 2', 'Week 3', 'Week 4', 'Week 5', 'Week 6', 'Week 7'],
                datasets: [{
                    label: 'Items Recovered',
                    data: [12, 19, 15, 25, 22, 30, 28],
                    borderColor: '#10b981',
                    backgroundColor: 'rgba(16, 185, 129, 0.1)',
                    fill: true,
                    tension: 0.4
                }, {
                    label: 'Claims Filed',
                    data: [20, 25, 20, 35, 28, 45, 40],
                    borderColor: '#3b82f6',
                    backgroundColor: 'transparent',
                    borderDash: [5, 5],
                    tension: 0.4
                }]
            },
            options: {
                maintainAspectRatio: false,
                plugins: {
                    legend: { position: 'bottom' }
                },
                scales: {
                    y: { beginAtZero: true, grid: { color: '#f1f5f9' } },
                    x: { grid: { display: false } }
                }
            }
        });
    </script>
}