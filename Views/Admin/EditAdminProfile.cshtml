@model Lost_Found.Models.User

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Update Officer Profile";
}

<div class="page-header" style="margin-bottom: 32px;">
    <div class="page-title">
        <h2>Update Officer Profile</h2>
        <p>Modify your administrative access credentials.</p>
    </div>
</div>

<div style="max-width: 600px;">
    <div style="background: white; padding: 40px; border-radius: 20px; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1); border: 1px solid #e2e8f0;">
        <form asp-action="EditAdminProfile" method="post" onsubmit="return validateAdminProfile(event)" novalidate>
            @Html.AntiForgeryToken()

            <!-- Validation Errors Display -->
            <div id="validationErrors" class="validation-errors" style="display: none;">
                <strong><i class="fas fa-exclamation-triangle"></i> Please fix the following errors:</strong>
                <ul id="errorList"></ul>
            </div>

            <div style="margin-bottom: 24px;">
                <label style="display: block; font-size: 13px; font-weight: 700; color: #64748b; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">Full Registered Name</label>
                <input type="text" id="adminName" name="user_name" value="@Model.user_name" style="width: 100%; padding: 14px; border: 1.5px solid #e2e8f0; border-radius: 10px; font-size: 15px; background: #f8fafc;" />
                <span class="input-error-text" id="adminNameError"></span>
            </div>

            <div style="margin-bottom: 24px;">
                <label style="display: block; font-size: 13px; font-weight: 700; color: #64748b; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">Institutional Email (Read-only)</label>
                <input type="email" value="@Model.user_email" readonly style="width: 100%; padding: 14px; border: 1.5px solid #e2e8f0; border-radius: 10px; font-size: 15px; background: #f1f5f9; color: #94a3b8; cursor: not-allowed;" />
                <small style="color: #94a3b8; display: block; margin-top: 6px;">Institutional emails are locked to the primary registration record.</small>
            </div>

            <div style="margin-bottom: 32px;">
                <label style="display: block; font-size: 13px; font-weight: 700; color: #64748b; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">New Access Key (Password)</label>
                <input type="password" id="adminPassword" name="password" placeholder="Leave blank to keep current" style="width: 100%; padding: 14px; border: 1.5px solid #e2e8f0; border-radius: 10px; font-size: 15px; background: #f8fafc;" />
                <span class="input-error-text" id="adminPasswordError"></span>
            </div>

            <div style="display: flex; gap: 16px;">
                <button type="submit" style="flex: 1; background: #0f172a; color: white; border: none; padding: 16px; border-radius: 10px; font-weight: 700; cursor: pointer; transition: all 0.2s;">
                    Save Official Changes
                </button>
                <a href="/Admin/AdminProfile" style="flex: 1; background: #f1f5f9; color: #1e293b; border: 1.5px solid #e2e8f0; padding: 16px; border-radius: 10px; font-weight: 700; text-decoration: none; text-align: center; transition: all 0.2s;">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>

<script src="~/js/register-validation.js"></script>
