@model IEnumerable<Lost_Found.Models.Item>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Admin Dashboard";
    var currentUser = Context.Session.GetString("UserName") ?? "Admin";
}

<div class="page-header">
    <div class="page-title">
        <h2>Dashboard Overview</h2>
        <p>Welcome back, @currentUser. Tracking campus activity in real-time.</p>
    </div>
</div>

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-info">
            <h3>Total Users</h3>
            <p>@ViewBag.TotalUsers</p>
        </div>
        <div class="stat-icon users">
            <i class="fas fa-users"></i>
        </div>
    </div>
    
    <div class="stat-card">
        <div class="stat-info">
            <h3>Registered Admins</h3>
            <p>@ViewBag.TotalAdmins</p>
        </div>
        <div class="stat-icon users" style="background: #f0f9ff; color: #0ea5e9;">
            <i class="fas fa-user-shield"></i>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-info">
            <h3>Logged Items</h3>
            <p>@ViewBag.TotalItems</p>
        </div>
        <div class="stat-icon items">
            <i class="fas fa-box"></i>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-info">
            <h3>Ongoing Claims</h3>
            <p>@Model.Count(i => i.Status == "Under Review")</p>
        </div>
        <div class="stat-icon claims">
            <i class="fas fa-hand-holding-heart"></i>
        </div>
    </div>
</div>

<div class="page-title" style="margin-bottom: 24px;">
    <h2>Recent Claim Activity</h2>
</div>

<div class="table-container">
    <table class="admin-table">
        <thead>
            <tr>
                <th>Item ID</th>
                <th>Item Title</th>
                <th>Type</th>
                <th>Current Status</th>
                <th>Date Logged</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="6" style="text-align: center; padding: 40px; color: #64748b;">No recent claim activity found.</td>
                </tr>
            }
            else
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td style="font-weight: 600; color: #64748b;">#@item.Id</td>
                        <td style="font-weight: 600;">@item.Title</td>
                        <td>
                            <span class="badge" style="background: @(item.Type == "Lost" ? "#fee2e2" : "#dcfce7"); color: @(item.Type == "Lost" ? "#ef4444" : "#15803d");">
                                @item.Type
                            </span>
                        </td>
                        <td>
                            @{
                                var statusClass = "badge-pending";
                                if (item.Status == "Claimed" || item.Status == "Resolved") statusClass = "badge-active";
                                else if (item.Status == "Rejected") statusClass = "badge-blocked";
                            }
                            <span class="badge @statusClass">@item.Status</span>
                        </td>
                        <td>@item.Date.ToString("MMM dd, yyyy")</td>
                        <td>
                            <a href="@Url.Action("Details", "Items", new { id = item.Id })" class="btn-action" style="color: #3b82f6;" title="Quick View">
                                <i class="fas fa-external-link-alt"></i>
                            </a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>