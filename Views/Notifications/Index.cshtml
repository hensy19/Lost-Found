@model IEnumerable<Lost_Found.Models.Notification>

@{
    Layout = "_Layout";
    ViewData["Title"] = "Your Notifications";
}

<div class="hp-page-bg">
    <div class="hp-container" style="max-width: 800px; padding: 60px 20px;">
        
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 style="font-weight: 800; color: #111827; margin: 0;">Notifications</h2>
                <p style="color: #6b7280; font-size: 14px;">Stay updated on your items and claims.</p>
            </div>
            @if (Model.Any())
            {
                <span class="badge bg-danger rounded-pill">@Model.Count() New</span>
            }
        </div>

        @if (!Model.Any())
        {
            <div class="card border-0 shadow-sm text-center p-5" style="border-radius: 20px;">
                <div style="background: #f3f4f6; width: 64px; height: 64px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px;">
                    <i class="fas fa-bell-slash" style="color: #9ca3af; font-size: 24px;"></i>
                </div>
                <h4 style="font-weight: 700; color: #374151;">All caught up!</h4>
                <p style="color: #6b7280; margin: 0;">You don't have any new notifications at the moment.</p>
                <a href="/Items/Index" class="btn btn-outline-success mt-4" style="border-radius: 10px; font-weight: 600;">Browse Items</a>
            </div>
        }
        else
        {
            <div class="notification-list">
                @foreach (var notification in Model)
                {
                    <div class="card border-0 shadow-sm mb-3 notification-card" 
                         id="notify-@notification.notification_id"
                         style="border-radius: 16px; border-left: 4px solid #10b981 !important; transition: all 0.2s;">
                        <div class="card-body p-4 d-flex justify-content-between align-items-center">
                            <div>
                                <p style="margin: 0; color: #111827; font-weight: 500; line-height: 1.5;">@notification.message</p>
                                <small style="color: #9ca3af; font-size: 12px; display: block; margin-top: 8px;">
                                    <i class="far fa-clock" style="margin-right: 4px;"></i> 
                                    @notification.created_at.ToString("MMM dd, h:mm tt")
                                </small>
                            </div>
                            <button onclick="dismissNotification(@notification.notification_id)" 
                                    class="btn-dismiss" 
                                    title="Dismiss"
                                    style="background: #f9fafb; border: none; width: 32px; height: 32px; border-radius: 8px; color: #9ca3af; cursor: pointer; transition: all 0.2s;">
                                <i class="fas fa-times"></i>
                            </button>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<script>
    function dismissNotification(id) {
        $.post('/Notifications/Dismiss/' + id, function() {
            const card = document.getElementById('notify-' + id);
            card.style.opacity = '0';
            card.style.transform = 'translateX(20px)';
            setTimeout(() => {
                card.remove();
                if (document.querySelectorAll('.notification-card').length === 0) {
                    location.reload(); // Show the empty state
                }
            }, 300);
        });
    }
</script>

<style>
    .notification-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1) !important;
    }
    .btn-dismiss:hover {
        background: #fee2e2 !important;
        color: #ef4444 !important;
    }
</style>
