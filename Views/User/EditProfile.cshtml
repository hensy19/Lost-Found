@model Lost_Found.Models.User

@{
    Layout = "_Layout";
    ViewData["Title"] = "Edit Profile";
}

<div class="hp-page-bg">
    <div class="hp-container" style="max-width: 600px; padding: 60px 20px;">
        
        <div class="card shadow-sm border-0" style="border-radius: 20px; overflow: hidden;">
            <div class="card-header bg-white border-0 pt-5 pb-2 text-center">
                <div style="background: #ecfdf5; width: 64px; height: 64px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px;">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                </div>
                <h2 style="font-weight: 800; color: #111827;">Update Profile</h2>
                <p style="color: #6b7280;">Modify your account details below</p>
            </div>

            <div class="card-body px-5 pb-5">
                <form asp-action="EditProfile" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-4">
                        <label class="form-label" style="font-weight: 600; color: #374151;">Full Name</label>
                        <input type="text" name="user_name" value="@Model.user_name" class="form-control" style="border-radius: 12px; border: 1.5px solid #e5e7eb; padding: 12px 16px; background: #f9fafb;" placeholder="Enter your full name" required />
                    </div>

                    <div class="mb-4">
                        <label class="form-label" style="font-weight: 600; color: #374151;">Email Address (Cannot be changed)</label>
                        <input type="email" value="@Model.user_email" class="form-control" style="border-radius: 12px; border: 1.5px solid #e5e7eb; padding: 12px 16px; background: #f3f4f6; color: #9ca3af; cursor: not-allowed;" readonly />
                    </div>

                    <div class="mb-5">
                        <label class="form-label" style="font-weight: 600; color: #374151;">New Password</label>
                        <input type="password" name="password" class="form-control" style="border-radius: 12px; border: 1.5px solid #e5e7eb; padding: 12px 16px; background: #f9fafb;" placeholder="Enter new password (optional)" />
                        <small class="text-muted">Leave blank to keep your current password</small>
                    </div>

                    <div class="d-flex gap-3">
                        <button type="submit" class="btn btn-primary w-100" style="background: #10b981; border: none; padding: 14px; border-radius: 12px; font-weight: 700; box-shadow: 0 4px 12px rgba(16, 185, 129, 0.2);">
                            Save Changes
                        </button>
                        <a href="/User/Profile" class="btn btn-light w-100" style="border: 1.5px solid #e5e7eb; padding: 14px; border-radius: 12px; font-weight: 700; color: #374151;">
                            Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>

    </div>
</div>
