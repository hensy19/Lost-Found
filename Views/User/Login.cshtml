@model Lost_Found.Models.User

@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lost & Found - Login</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="~/css/site.css" rel="stylesheet">
</head>
<body>
    <!-- Header with Logo -->
    <div class="header">
        <div class="header-icon">
            <i class="fas fa-briefcase"></i>
        </div>
        <span>Lost & Found</span>
    </div>

    <div class="register-container">
        <div class="form-card">
            <div style="text-align: center; margin-bottom: 25px;">
                <div style="font-size: 36px; margin-bottom: 15px; color: #5ec39d;">
                    <i class="fas fa-sign-in-alt"></i>
                </div>
                <h1 class="form-title">Welcome Back</h1>
                <p class="form-subtitle">Sign in to your Lost & Found account</p>
            </div>

            @if (!string.IsNullOrEmpty(ViewBag.Error))
            {
                <div class="form-error">
                    <i class="fas fa-exclamation-circle"></i> @ViewBag.Error
                </div>
            }

            <form asp-action="Login" method="post" onsubmit="return validateLoginForm(event)">
                <!-- Validation Errors Display -->
                <div id="validationErrors" class="validation-errors" style="display: none;">
                    <strong><i class="fas fa-exclamation-triangle"></i> Please fix the following errors:</strong>
                    <ul id="errorList"></ul>
                </div>

                <!-- Email Address -->
                <div class="form-group">
                    <label class="form-label">
                        <i class="fas fa-envelope" style="margin-right: 5px;"></i>Email Address
                    </label>
                    <input type="text" id="email" name="email" class="form-control" placeholder="your@example.com" />
                    <span class="input-error-text" id="emailError"></span>
                </div>

                <!-- Password -->
                <div class="form-group">
                    <label class="form-label">
                        <i class="fas fa-lock" style="margin-right: 5px;"></i>Password
                    </label>
                    <input type="password" id="password" name="password" class="form-control" placeholder="••••••••" />
                    <span class="input-error-text" id="passwordError"></span>
                </div>

                <!-- Remember Me Checkbox -->
                <div class="checkbox-group" style="margin: 20px 0;">
                    <input type="checkbox" id="rememberMe" name="rememberMe" />
                    <label for="rememberMe" style="margin: 0;">
                        Remember me on this device
                    </label>
                </div>

                <!-- Login Button -->
                <button type="submit" class="btn-register" style="margin-bottom: 20px;">
                    <span>Sign In</span>
                    <i class="fas fa-arrow-right"></i>
                </button>

                <!-- Register Link -->
                <div class="login-link">
                    Don't have an account? <a href="/User/Register">Create one here</a>
                </div>
            </form>
        </div>

        <div class="footer-text">
            Trusted by 20k+ students
        </div>
    </div>

    <script src="~/js/register-validation.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
