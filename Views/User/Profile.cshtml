@{
    Layout = "_Layout";
    ViewData["Title"] = "Profile";
}

<div class="hp-page-bg">
    <div class="hp-container hp-profile-container">

        <!-- Header Card -->
        <div class="hp-profile-header">
            <div class="hp-profile-header-content">
                <div class="hp-profile-avatar-wrap">
                    <img src="https://images.unsplash.com/photo-1544723795-3cb6a8d0edc0?w=150&h=150&fit=crop" alt="Arav Jain" class="hp-profile-avatar" />
                </div>
                <div class="hp-profile-info">
                    <div class="hp-profile-name-row">
                        <h1 class="hp-profile-name">Arav Jain</h1>
                        <span class="hp-badge-student">STUDENT</span>
                    </div>
                    <p class="hp-profile-major">Environmental Science Major &bull; Class of 2025</p>
                </div>
            </div>
            <div class="hp-profile-actions">
                <button class="hp-btn-edit-profile">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                    Edit Profile
                </button>
            </div>
        </div>

        <!-- Stats Row -->
        <div class="hp-stats-row">
            <div class="hp-stat-card">
                <div class="hp-stat-icon">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#1a7a4c" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
                </div>
                <div class="hp-stat-value">12</div>
                <div class="hp-stat-label">ITEMS REPORTED</div>
            </div>
            <div class="hp-stat-card">
                <div class="hp-stat-icon">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#1a7a4c" stroke-width="1.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                </div>
                <div class="hp-stat-value">08</div>
                <div class="hp-stat-label">ITEMS FOUND</div>
            </div>
            <div class="hp-stat-card">
                <div class="hp-stat-icon">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#1a7a4c" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                </div>
                <div class="hp-stat-value">05</div>
                <div class="hp-stat-label">PEOPLE HELPED</div>
            </div>
            <div class="hp-stat-card">
                <div class="hp-stat-icon">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#1a7a4c" stroke-width="1.5"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                </div>
                <div class="hp-stat-value">2y</div>
                <div class="hp-stat-label">ACCOUNT AGE</div>
            </div>
        </div>

        <!-- Tabs -->
        <div class="hp-tabs-container">
            <div class="hp-tabs">
                <div class="hp-tab active">My Reports</div>
                <div class="hp-tab">Saved Items</div>
                <div class="hp-tab">Account Settings</div>
            </div>
        </div>

        <!-- Reports Grid -->
        <div class="hp-reports-grid">
            <!-- Card 1 -->
            <div class="hp-report-card">
                <div class="hp-report-img-wrapper">
                    <img src="https://images.unsplash.com/photo-1517336714731-489689fd1ca8?w=500&h=300&fit=crop" alt="MacBook Pro" />
                    <span class="hp-report-badge found">FOUND</span>
                </div>
                <div class="hp-report-body">
                    <h3 class="hp-report-title">MacBook Pro 14"</h3>
                    <p class="hp-report-desc">Left in the North Wing Library, Level 2, near the window seats. Silver color with a green leaf sticker.</p>
                </div>
                <div class="hp-report-footer">
                    <span class="hp-report-date">OCT 24, 2024</span>
                    <a href="#" class="hp-report-link">View Details</a>
                </div>
            </div>
            
            <!-- Card 2 -->
            <div class="hp-report-card">
                <div class="hp-report-img-wrapper">
                    <img src="https://images.unsplash.com/photo-1627123424574-724758594e93?w=500&h=300&fit=crop" alt="Brown Leather Wallet" />
                    <span class="hp-report-badge searching">SEARCHING</span>
                </div>
                <div class="hp-report-body">
                    <h3 class="hp-report-title">Brown Leather Wallet</h3>
                    <p class="hp-report-desc">Lost somewhere between the Science Quad and the Student Union. Contains Student ID and gym pass.</p>
                </div>
                <div class="hp-report-footer">
                    <span class="hp-report-date">OCT 20, 2024</span>
                    <a href="#" class="hp-report-link">View Details</a>
                </div>
            </div>

            <!-- Card 3 -->
            <div class="hp-report-card">
                <div class="hp-report-img-wrapper">
                    <img src="https://images.unsplash.com/photo-1628202926206-c63a34b1618f?w=500&h=300&fit=crop" alt="AirPods Case" />
                    <span class="hp-report-badge found">FOUND</span>
                </div>
                <div class="hp-report-body">
                    <h3 class="hp-report-title">AirPods Case</h3>
                    <p class="hp-report-desc">Found at the gym lockers. Charging case only, white color, with a small scratch on the front.</p>
                </div>
                <div class="hp-report-footer">
                    <span class="hp-report-date">OCT 15, 2024</span>
                    <a href="#" class="hp-report-link">View Details</a>
                </div>
            </div>
        </div>

    </div>
</div>
