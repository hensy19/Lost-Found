@model Lost_Found.Models.User

@{
    Layout = "_Layout";
    ViewData["Title"] = "Profile";
    var reportedCount = Model.ReportedItems?.Count(i => i.Type == "Lost") ?? 0;
    var foundCount = Model.ReportedItems?.Count(i => i.Type == "Found") ?? 0;
    var totalItems = Model.ReportedItems?.Count ?? 0;
}

<div class="hp-page-bg">
    <div class="hp-container hp-profile-container">

        <!-- Header Card -->
        <div class="hp-profile-header">
            <div class="hp-profile-header-content">
                <div class="hp-profile-avatar-wrap">
                    <img src="https://ui-avatars.com/api/?name=@Model.user_name&background=1a7a4c&color=fff&size=150" alt="@Model.user_name" class="hp-profile-avatar" />
                </div>
                <div class="hp-profile-info">
                    <div class="hp-profile-name-row">
                        <h1 class="hp-profile-name">@Model.user_name</h1>
                        <span class="hp-badge-student">@Model.role.ToString().ToUpper()</span>
                    </div>
                    <p class="hp-profile-major">@Model.user_email &bull; Joined @Model.created_at.ToString("MMMM yyyy")</p>
                </div>
            </div>
            <div class="hp-profile-actions">
                <a href="/User/EditProfile" class="hp-btn-edit-profile" style="text-decoration: none; display: flex; align-items: center; justify-content: center; gap: 8px;">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                    Edit Profile
                </a>
            </div>
        </div>

        <!-- Stats Row -->
        <div class="hp-stats-row">
            <div class="hp-stat-card">
                <div class="hp-stat-icon">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#1a7a4c" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
                </div>
                <div class="hp-stat-value">@reportedCount</div>
                <div class="hp-stat-label">ITEMS REPORTED</div>
            </div>
            <div class="hp-stat-card">
                <div class="hp-stat-icon">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#1a7a4c" stroke-width="1.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                </div>
                <div class="hp-stat-value">@foundCount</div>
                <div class="hp-stat-label">ITEMS FOUND</div>
            </div>
            <div class="hp-stat-card">
                <div class="hp-stat-icon">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#1a7a4c" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                </div>
                <div class="hp-stat-value">@(reportedCount + foundCount)</div>
                <div class="hp-stat-label">TOTAL LISTINGS</div>
            </div>
            <div class="hp-stat-card">
                <div class="hp-stat-icon">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#1a7a4c" stroke-width="1.5"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                </div>
                @{
                    var daysSinceJoined = (DateTime.Now - @Model.created_at).Days;
                    var accountAge = daysSinceJoined > 365 ? (daysSinceJoined / 365) + "y" : daysSinceJoined + "d";
                }
                <div class="hp-stat-value">@accountAge</div>
                <div class="hp-stat-label">ACCOUNT AGE</div>
            </div>
        </div>

        <!-- Tabs -->
        <div class="hp-tabs-container">
            <div class="hp-tabs">
                <div class="hp-tab active">My Reports (@totalItems)</div>
            </div>
        </div>

        <!-- Reports Grid -->
        <div class="hp-reports-grid">
            @if (Model.ReportedItems != null && Model.ReportedItems.Any())
            {
                @foreach (var item in Model.ReportedItems.OrderByDescending(i => i.Id))
                {
                    <div class="hp-report-card">
                        <div class="hp-report-img-wrapper">
                            <img src="@(item.ImagePath ?? "/images/default.png")" alt="@item.Title" />
                            <span class="hp-report-badge @(item.Type.ToLower())">@item.Type.ToUpper()</span>
                        </div>
                        <div class="hp-report-body">
                            <h3 class="hp-report-title">@item.Title</h3>
                            <p class="hp-report-desc">@item.Description</p>
                        </div>
                        <div class="hp-report-footer">
                            <span class="hp-report-date">@item.Date.ToString("MMM dd, yyyy")</span>
                            <a href="/Items/Details/@item.Id" class="hp-report-link">View Details</a>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="text-center w-100 py-5" style="grid-column: 1 / -1;">
                    <p style="color: #6b7280; font-size: 16px;">You haven't reported any items yet.</p>
                    <a href="/Items/ReportItem" class="btn btn-primary" style="background:#1a7a4c; border:none; padding: 10px 20px; border-radius: 8px;">Report an Item</a>
                </div>
            }
        </div>

    </div>
</div>
