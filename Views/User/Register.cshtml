@model Lost_Found.Models.User

@{
    ViewData["Title"] = "Register";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lost & Found - Register</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="~/css/site.css" rel="stylesheet">
</head>
<body>
    <!-- Header with Logo -->
    <div class="header">
        <div class="header-icon">
            <i class="fas fa-briefcase"></i>
        </div>
        <span>Lost & Found</span>
    </div>

    <div class="register-container">
        <div class="form-card">
            <div style="text-align: center; margin-bottom: 25px;">
                <div style="font-size: 36px; margin-bottom: 15px; color: #5ec39d;">
                    <i class="fas fa-users"></i>
                </div>
                <h1 class="form-title">Create Your Account</h1>
                <p class="form-subtitle">Join the campus lost & found community</p>
            </div>

            @if (!string.IsNullOrEmpty(ViewBag.Error))
            {
                <div class="form-error">
                    <i class="fas fa-exclamation-circle"></i> @ViewBag.Error
                </div>
            }

            <form asp-action="Register" method="post" onsubmit="return validateForm(event)">
                <!-- Validation Errors Display -->
                <div id="validationErrors" class="validation-errors" style="display: none;">
                    <strong><i class="fas fa-exclamation-triangle"></i> Please fix the following errors:</strong>
                    <ul id="errorList"></ul>
                </div>

                <!-- Full Name -->
                <div class="form-group">
                    <label class="form-label">
                        <i class="fas fa-user" style="margin-right: 5px;"></i>Full Name
                    </label>
                    <input type="text" id="fullName" asp-for="user_name" class="form-control" placeholder="Alex Rivers" />
                    <span class="input-error-text" id="fullNameError"></span>
                </div>

                <!-- Email Address -->
                <div class="form-group">
                    <label class="form-label">
                        <i class="fas fa-envelope" style="margin-right: 5px;"></i>Email Address
                    </label>
                    <input type="text" id="email" asp-for="user_email" class="form-control" placeholder="alex@campus.edu" />
                    <span class="input-error-text" id="emailError"></span>
                </div>

                <!-- Campus Role -->
                <div class="form-group">
                    <label class="form-label">
                        <i class="fas fa-id-badge" style="margin-right: 5px;"></i>Your Campus Role
                    </label>
                    <div class="role-toggle">
                        <button type="button" class="role-btn active" data-role="User" onclick="selectRole(this)">
                            <i class="fas fa-graduation-cap"></i> Student
                        </button>
                        <button type="button" class="role-btn" data-role="Admin" onclick="selectRole(this)">
                            <i class="fas fa-shield-alt"></i> Admin
                        </button>
                    </div>
                    <input type="hidden" id="roleInput" asp-for="role" value="User" />
                </div>

                <!-- Password Row -->
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">
                            <i class="fas fa-lock" style="margin-right: 5px;"></i>Password
                        </label>
                        <input type="password" id="password" asp-for="password" class="form-control" placeholder="••••••••" />
                        <span class="input-error-text" id="passwordError"></span>
                        <small style="color: #666; display: block; margin-top: 5px;">Minimum 6 characters</small>
                    </div>
                    <div class="form-group">
                        <label class="form-label">
                            <i class="fas fa-lock" style="margin-right: 5px;"></i>Confirm
                        </label>
                        <input type="password" id="confirmPassword" class="form-control" placeholder="••••••••" />
                        <span class="input-error-text" id="confirmPasswordError"></span>
                    </div>
                </div>

                <!-- Terms Checkbox -->
                <div class="checkbox-group">
                    <input type="checkbox" id="terms" name="terms" />
                    <label for="terms" style="margin: 0;">
                        I agree to the <a href="#">Community Guidelines</a> and authorize the handling of my item data.
                    </label>
                    <span class="input-error-text d-block" id="termsError"></span>
                </div>

                <!-- Register Button -->
                <button type="submit" class="btn-register">
                    <span>Register Account</span>
                    <i class="fas fa-arrow-right"></i>
                </button>

                <!-- Login Link -->
                <div class="login-link">
                    Already have an account? <a href="/User/Login">Log in here</a>
                </div>
            </form>
        </div>

        <div class="footer-text">
            Trusted by 20k+ students
        </div>
    </div>

    <script src="~/js/register-validation.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

