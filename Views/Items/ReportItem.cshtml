<link rel="stylesheet" href="~/css/report-item.css" />

@model Lost_Found.Models.Item

<div class="container mt-5">
    <div class="card p-4 shadow-lg report-card">

        <h3 class="mb-4">Report Item</h3>

        <!-- 🔁 Modern Toggle -->
        <div class="toggle-container mb-4">
            <div class="toggle-pill">
                <div class="toggle-slider" id="slider"></div>

                <button type="button" class="toggle-option active" onclick="setType('Lost')">
                    Lost
                </button>

                <button type="button" class="toggle-option" onclick="setType('Found')">
                    Found
                </button>
            </div>
        </div>
        <form asp-action="ReportItem" method="post" enctype="multipart/form-data">

            <input type="hidden" id="itemType" name="Type" value="Lost" />

            <div class="mb-3">
                <label>Item Name *</label>
                <input name="Title" class="form-control custom-input" placeholder="e.g. Blue Backpack" required />
            </div>

            <div class="mb-3">
                <label>Category *</label>
                <select name="Category" class="form-control custom-input" required>
                    <option>Electronics</option>
                    <option>Accessories</option>
                    <option>Documents</option>
                    <option>Clothing</option>
                    <option>Books</option>
                    <option>Others</option>
                </select>
            </div>

            <div class="mb-3">
                <label>Location *</label>
                <select name="Location" class="form-control custom-input" required>
                    <option>Library</option>
                    <option>Cafeteria</option>
                    <option>Classroom</option>
                    <option>Hostel</option>
                    <option>Playground</option>
                    <option>Parking Area</option>
                </select>
            </div>
            <div class="mb-3">
                <label>Date *</label>
				<input type="date" name="Date" class="form-control custom-input" required />        
            </div>

            <div class="mb-3">
                <label>Description *</label>
                <textarea name="Description" class="form-control custom-input" required></textarea>
            </div>

            <div class="mb-3">
                <label>Upload Image (Optional)</label>
                <input type="file" name="imageFile" class="form-control file-upload" />
            </div>

            <button class="btn submit-btn w-100">Submit</button>

        </form>
    </div>
</div>
<script>
    function setType(type) {
        document.getElementById("itemType").value = type;

        let buttons = document.querySelectorAll(".toggle-option");
        let slider = document.getElementById("slider");

        buttons.forEach(btn => btn.classList.remove("active"));

        if (type === "Lost") {
            buttons[0].classList.add("active");
            slider.style.left = "0%";
        } else {
            buttons[1].classList.add("active");
            slider.style.left = "50%";
        }
    }
</script>