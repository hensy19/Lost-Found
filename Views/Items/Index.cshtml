@model List<Lost_Found.Models.Item>

@{
    Layout = "_Layout";
    ViewData["Title"] = "Browse Items";
}

<div class="hp-page-bg">
    <div class="hp-container">
        
        <!-- 🔍 Header with CTA -->
        <div class="page-header mb-5" style="display: flex; justify-content: space-between; align-items: flex-end; flex-wrap: wrap; gap: 20px;">
            <div class="page-title">
                <h2 class="fw-bold" style="font-size: 36px; color: #111827; margin: 0;">Campus Discovery</h2>
                <p style="color: #6b7280; font-size: 16px; margin: 4px 0 0 0;">@Model.Count items waiting to be reclaimed.</p>
            </div>
        </div>

        <!--  Filter Bar -->
        <div class="filter-bar mb-5" style="background: white; padding: 20px; border-radius: 16px; box-shadow: 0 4px 16px rgba(0,0,0,0.03); display: flex; gap: 16px; align-items: center; flex-wrap: wrap;">
            <input type="text" id="searchBox" placeholder="Search by title, location, date or category..." onkeyup="filterItems()" class="form-control" style="flex: 1; border-radius: 12px; border: 1px solid #e5e7eb; padding: 12px 16px;" />

            <select id="categoryFilter" onchange="filterItems()" class="form-select" style="width: auto; min-width: 160px; border-radius: 12px; border: 1px solid #e5e7eb; padding: 12px 36px 12px 16px;">
                <option value="">All Categories</option>
                <option>Electronics</option>
                <option>Accessories</option>
                <option>Documents</option>
                <option>Clothing</option>
                <option>Books</option>
                <option>Bags</option>
            </select>

            <select id="typeFilter" onchange="filterItems()" class="form-select" style="width: auto; min-width: 130px; border-radius: 12px; border: 1px solid #e5e7eb; padding: 12px 36px 12px 16px;">
                <option value="">All Types</option>
                <option>Lost</option>
                <option>Found</option>
            </select>
        </div>

        @if (!Model.Any())
        {
            <div class="text-center mt-5">
                <h5>No items found 😕</h5>
            </div>
        }

        <!-- 🧾 Items Grid -->
        <div class="hp-items-grid" id="itemsContainer">
            @foreach (var item in Model)
            {
                <div class="hp-item-card item-filter-card" 
                     data-title="@item.Title" 
                     data-category="@item.Category" 
                     data-type="@item.Type"
                     data-location="@item.Location"
                     data-date="@item.Date.ToString("MMM dd yyyy")">
                    <a href="/Items/Details/@item.Id" style="text-decoration: none; color: inherit; display: block; height: 100%;">
                        <div class="hp-item-img-wrap">
                            <img src="@(item.ImagePath ?? "/images/default.png")" alt="@item.Title" />
                            @if (item.Type == "Lost")
                            {
                                <span class="hp-tag-found" style="background:#ef4444;">LOST</span>
                            }
                            else
                            {
                                <span class="hp-tag-found" style="background:#1a7a4c;">FOUND</span>
                            }
                        </div>
                        <div class="hp-item-info">
                            <h4>@item.Title</h4>
                            <p style="margin:0; font-size:13px; color:#6b7280; font-weight:600;">@item.Category</p>
                            <p style="margin:4px 0 12px; font-size:12px; color:#9ca3af;">@item.Location &bull; @item.Date.ToString("MMM dd yyyy")</p>
                            
                            @if (item.Status != "Active")
                            {
                                <span class="badge" style="background: #f3f4f6; color: #4b5563; padding: 6px 12px; border-radius: 12px; font-size: 11px; margin-bottom: 12px; display: inline-block;">@item.Status</span>
                            }

                            <div>
                                <span class="hp-btn-details d-inline-block">View Details</span>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
    </div>
</div>

<script>
    window.onload = function() {
        var initialCategory = "@ViewBag.Category";
        if (initialCategory) {
            var categorySelect = document.getElementById("categoryFilter");
            categorySelect.value = initialCategory;
        }
        filterItems();
    };

    function filterItems() {
        let search = document.getElementById("searchBox").value.toLowerCase();
        let category = document.getElementById("categoryFilter").value;
        let type = document.getElementById("typeFilter").value;

        let items = document.querySelectorAll(".item-filter-card");

        items.forEach(item => {
            let title = item.dataset.title.toLowerCase();
            let itemCategory = item.dataset.category.toLowerCase();
            let itemType = item.dataset.type.toLowerCase();
            let location = item.dataset.location.toLowerCase();
            let date = item.dataset.date.toLowerCase();

            // Combined search across multiple fields
            let combinedText = `${title} ${itemCategory} ${location} ${date}`;
            
            let matchSearch = combinedText.includes(search);
            let matchCategory = category === "" || itemCategory === category.toLowerCase();
            let matchType = type === "" || itemType === type.toLowerCase();

            item.style.display = (matchSearch && matchCategory && matchType) ? "block" : "none";
        });
    }
</script>
